# API
# Base URL for server-side and client-side API requests
NUXT_PUBLIC_API_BASE_URL=http://localhost:3001

# Site
# Used for canonical URLs and OG tags in useSeo()
NUXT_PUBLIC_SITE_URL=http://localhost:3000

# App
# Display name used in the default layout header/footer
NUXT_PUBLIC_APP_NAME=My App
