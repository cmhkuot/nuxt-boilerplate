    "clsx": "^2.1.1",
    "nuxt": "^4.4.5",
    "nuxt-svgo": "^5.3.0",
    "pinia": "^3.0.4",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "vue": "^3.5.34",
    "vue-router": "^5.0.7"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.15.2",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
